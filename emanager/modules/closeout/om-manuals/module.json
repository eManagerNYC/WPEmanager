{
	"id": "om-manuals",
	"name": "O&M Manuals",
	"section": "closeout",
	"icon": "bi-book",
	"table": "em_om_manuals",
	"version": "1.0.0",
	"statuses": [
		"Requested",
		"Received",
		"Under Review",
		"Accepted",
		"Transmitted to Owner"
	],
	"fields": [
		{
			"name": "title",
			"label": "Manual title",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "spec_section",
			"label": "Spec section",
			"type": "text",
			"list": true
		},
		{
			"name": "subcontractor",
			"label": "Responsible subcontractor",
			"type": "combo",
			"source": "companies",
			"list": true
		},
		{
			"name": "received_date",
			"label": "Received",
			"type": "date",
			"list": true
		},
		{
			"name": "file_url",
			"label": "Document link",
			"type": "url"
		},
		{
			"name": "notes",
			"label": "Notes",
			"type": "textarea"
		}
	],
	"workflow": {
		"initial": "Requested",
		"states": {
			"Requested": {
				"transitions": [
					{
						"to": "Received",
						"label": "Mark received",
						"party": [
							"subcontractor",
							"gc"
						]
					}
				]
			},
			"Received": {
				"transitions": [
					{
						"to": "Under Review",
						"label": "Begin review",
						"party": [
							"gc"
						]
					}
				]
			},
			"Under Review": {
				"transitions": [
					{
						"to": "Accepted",
						"label": "Accept",
						"party": [
							"gc",
							"consultant"
						]
					},
					{
						"to": "Received",
						"label": "Return to sub",
						"party": [
							"gc"
						]
					}
				]
			},
			"Accepted": {
				"transitions": [
					{
						"to": "Transmitted to Owner",
						"label": "Transmit to owner",
						"party": [
							"gc"
						]
					}
				]
			},
			"Transmitted to Owner": {
				"transitions": []
			}
		}
	}
}
