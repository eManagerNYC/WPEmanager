{
	"id": "completion-certificates",
	"name": "Completion Certificates",
	"section": "closeout",
	"icon": "bi-patch-check",
	"table": "em_completion_certificates",
	"version": "1.0.0",
	"statuses": [
		"Draft",
		"Issued",
		"Executed"
	],
	"fields": [
		{
			"name": "cert_no",
			"label": "Certificate #",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "cert_type",
			"label": "Type",
			"type": "select",
			"options": [
				"Substantial Completion",
				"Final Completion",
				"Partial Occupancy",
				"Temporary CO",
				"Certificate of Occupancy"
			],
			"required": true,
			"list": true
		},
		{
			"name": "description",
			"label": "Scope / area",
			"type": "text",
			"list": true
		},
		{
			"name": "issue_date",
			"label": "Issue date",
			"type": "date",
			"list": true
		},
		{
			"name": "value_remaining",
			"label": "Value of remaining work",
			"type": "currency"
		},
		{
			"name": "notes",
			"label": "Notes",
			"type": "textarea"
		}
	],
	"workflow": {
		"initial": "Draft",
		"states": {
			"Draft": {
				"transitions": [
					{
						"to": "Issued",
						"label": "Issue",
						"party": [
							"gc",
							"consultant"
						]
					}
				]
			},
			"Issued": {
				"transitions": [
					{
						"to": "Executed",
						"label": "Execute",
						"party": [
							"owner",
							"rep"
						]
					}
				]
			},
			"Executed": {
				"transitions": []
			}
		}
	},
	"relations": [
		{
			"spawn": "warranties",
			"label": "Start warranty (period begins)",
			"map": {
				"item": "description",
				"start_date": "issue_date"
			}
		}
	]
}
