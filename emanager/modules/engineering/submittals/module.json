{
	"id": "submittals",
	"name": "Submittals",
	"section": "engineering",
	"icon": "bi-file-earmark-arrow-up",
	"table": "em_submittals",
	"version": "1.0.0",
	"statuses": [
		"Draft",
		"Submitted",
		"GC Review",
		"A/E Review",
		"Returned",
		"Closed"
	],
	"fields": [
		{
			"name": "number",
			"label": "Submittal number",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "revision",
			"label": "Revision",
			"type": "text",
			"list": true
		},
		{
			"name": "submittal_type",
			"label": "Type",
			"type": "select",
			"options": [
				"Shop Drawing",
				"Product Data",
				"Sample",
				"Mock-up",
				"Certificate",
				"Test Report",
				"O&M Data",
				"Closeout"
			],
			"list": true
		},
		{
			"name": "title",
			"label": "Title",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "spec_section",
			"label": "Spec section",
			"type": "text",
			"list": true
		},
		{
			"name": "subcontractor",
			"label": "Subcontractor",
			"type": "text",
			"list": true
		},
		{
			"name": "ball_in_court",
			"label": "Ball in court",
			"type": "text",
			"list": true
		},
		{
			"name": "reviewer",
			"label": "A/E reviewer",
			"type": "text"
		},
		{
			"name": "lead_time_days",
			"label": "Lead time (days)",
			"type": "number"
		},
		{
			"name": "required_on_site",
			"label": "Required on site",
			"type": "date",
			"list": true
		},
		{
			"name": "date_received",
			"label": "Date received",
			"type": "date"
		},
		{
			"name": "date_returned",
			"label": "Date returned",
			"type": "date",
			"list": true
		},
		{
			"name": "reviewer_notes",
			"label": "Reviewer notes",
			"type": "textarea"
		},
		{
			"name": "file_url",
			"label": "Document link",
			"type": "url"
		}
	],
	"workflow": {
		"initial": "Draft",
		"states": {
			"Draft": {
				"transitions": [
					{
						"to": "Submitted",
						"label": "Submit",
						"party": [
							"subcontractor"
						]
					}
				]
			},
			"Submitted": {
				"transitions": [
					{
						"to": "GC Review",
						"label": "Begin GC review",
						"party": [
							"gc"
						]
					},
					{
						"to": "Draft",
						"label": "Return to subcontractor",
						"party": [
							"gc"
						]
					}
				]
			},
			"GC Review": {
				"transitions": [
					{
						"to": "A/E Review",
						"label": "Forward to A/E",
						"party": [
							"gc"
						]
					},
					{
						"to": "Draft",
						"label": "Return to subcontractor",
						"party": [
							"gc"
						]
					}
				]
			},
			"A/E Review": {
				"transitions": [
					{
						"to": "Returned",
						"label": "Return disposition",
						"party": [
							"consultant"
						],
						"directions": [
							"Approved",
							"Approved as Noted",
							"Revise & Resubmit",
							"Rejected"
						]
					}
				]
			},
			"Returned": {
				"transitions": [
					{
						"to": "Closed",
						"label": "Close (approved)",
						"party": [
							"gc"
						]
					},
					{
						"to": "Draft",
						"label": "Revise & resubmit",
						"party": [
							"gc",
							"subcontractor"
						]
					}
				]
			},
			"Closed": {
				"transitions": []
			}
		}
	}
}
