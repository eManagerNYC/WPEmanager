{
	"id": "meetings",
	"name": "Meeting Agenda / Minutes",
	"section": "engineering",
	"icon": "bi-calendar3",
	"table": "em_meetings",
	"version": "1.0.0",
	"statuses": [
		"Scheduled",
		"Agenda Issued",
		"Held",
		"Minutes Issued"
	],
	"fields": [
		{
			"name": "title",
			"label": "Meeting title",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "meeting_no",
			"label": "Meeting number",
			"type": "text",
			"list": true
		},
		{
			"name": "meeting_type",
			"label": "Type",
			"type": "select",
			"options": [
				"OAC",
				"Subcontractor",
				"Safety",
				"Preconstruction",
				"Coordination",
				"Progress",
				"Other"
			],
			"list": true
		},
		{
			"name": "meeting_date",
			"label": "Date & time",
			"type": "datetime",
			"required": true,
			"list": true
		},
		{
			"name": "location",
			"label": "Location",
			"type": "select",
			"lookup": {
				"module": "locations",
				"value": "name",
				"label": "name"
			}
		},
		{
			"name": "attendees",
			"label": "Attendees",
			"type": "textarea"
		},
		{
			"name": "agenda",
			"label": "Agenda",
			"type": "textarea"
		},
		{
			"name": "minutes",
			"label": "Minutes",
			"type": "textarea"
		},
		{
			"name": "next_meeting",
			"label": "Next meeting",
			"type": "datetime"
		}
	],
	"workflow": {
		"initial": "Scheduled",
		"states": {
			"Scheduled": {
				"transitions": [
					{
						"to": "Agenda Issued",
						"label": "Issue agenda",
						"party": [
							"gc"
						]
					}
				]
			},
			"Agenda Issued": {
				"transitions": [
					{
						"to": "Held",
						"label": "Mark held",
						"party": [
							"gc"
						]
					}
				]
			},
			"Held": {
				"transitions": [
					{
						"to": "Minutes Issued",
						"label": "Issue minutes",
						"party": [
							"gc"
						]
					}
				]
			},
			"Minutes Issued": {
				"transitions": [
					{
						"to": "Held",
						"label": "Revise minutes",
						"party": [
							"gc"
						]
					}
				]
			}
		}
	},
	"relations": [
		{
			"spawn": "action-items",
			"label": "Create action item",
			"map": {
				"title": "title",
				"source": "title"
			}
		}
	]
}
