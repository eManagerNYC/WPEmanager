{
	"id": "rfis",
	"name": "RFIs",
	"section": "engineering",
	"icon": "bi-question-circle",
	"table": "em_rfis",
	"version": "1.0.0",
	"statuses": [
		"Draft",
		"Open",
		"Answered",
		"Closed",
		"Void"
	],
	"fields": [
		{
			"name": "number",
			"label": "RFI number",
			"type": "text",
			"list": true,
			"auto": "RFI-",
			"help": "Leave blank to auto-number."
		},
		{
			"name": "subject",
			"label": "Subject",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "discipline",
			"label": "Discipline",
			"type": "select",
			"options": [
				"Architectural",
				"Structural",
				"Civil",
				"Mechanical",
				"Electrical",
				"Plumbing",
				"Fire Protection",
				"Other"
			],
			"list": true
		},
		{
			"name": "priority",
			"label": "Priority",
			"type": "select",
			"options": [
				"Low",
				"Normal",
				"High",
				"Critical"
			],
			"list": true
		},
		{
			"name": "question",
			"label": "Question",
			"type": "textarea",
			"required": true
		},
		{
			"name": "ball_in_court",
			"label": "Ball in court",
			"type": "text",
			"list": true,
			"help": "Party currently responsible for the next action."
		},
		{
			"name": "assigned_to",
			"label": "Assigned reviewer (Consultant)",
			"type": "combo",
			"source": "users",
			"list": true
		},
		{
			"name": "date_submitted",
			"label": "Date submitted",
			"type": "date",
			"list": true
		},
		{
			"name": "date_required",
			"label": "Response required by",
			"type": "date",
			"list": true
		},
		{
			"name": "drawing_ref",
			"label": "Drawing / spec reference",
			"type": "text"
		},
		{
			"name": "answer",
			"label": "Official response",
			"type": "textarea"
		},
		{
			"name": "responded_by",
			"label": "Responded by",
			"type": "text"
		},
		{
			"name": "response_date",
			"label": "Response date",
			"type": "date"
		},
		{
			"name": "cost_impact",
			"label": "Cost impact?",
			"type": "checkbox"
		},
		{
			"name": "cost_impact_amount",
			"label": "Estimated cost impact",
			"type": "currency"
		},
		{
			"name": "schedule_impact",
			"label": "Schedule impact?",
			"type": "checkbox"
		},
		{
			"name": "schedule_impact_days",
			"label": "Schedule impact (days)",
			"type": "number"
		},
		{
			"name": "distribution",
			"label": "Distribution",
			"type": "textarea"
		},
		{
			"name": "file_url",
			"label": "Attachment link",
			"type": "url"
		}
	],
	"workflow": {
		"initial": "Draft",
		"states": {
			"Draft": {
				"transitions": [
					{
						"to": "Open",
						"label": "Submit RFI",
						"party": [
							"gc"
						]
					}
				]
			},
			"Open": {
				"transitions": [
					{
						"to": "Answered",
						"label": "Respond",
						"party": [
							"consultant"
						],
						"requires": [
							"answer"
						]
					},
					{
						"to": "Void",
						"label": "Void",
						"party": [
							"gc"
						]
					}
				]
			},
			"Answered": {
				"transitions": [
					{
						"to": "Closed",
						"label": "Accept & close",
						"party": [
							"gc"
						]
					},
					{
						"to": "Open",
						"label": "Reopen / clarify",
						"party": [
							"gc"
						]
					}
				]
			},
			"Closed": {
				"transitions": []
			},
			"Void": {
				"transitions": []
			}
		}
	},
	"relations": [
		{
			"spawn": "change-events",
			"label": "Raise change event",
			"map": {
				"title": "subject",
				"description": "question"
			}
		}
	]
}
