{
	"id": "change-orders",
	"name": "Change Orders",
	"section": "cost",
	"icon": "bi-arrow-repeat",
	"table": "em_change_orders",
	"version": "1.0.0",
	"statuses": [
		"Draft",
		"Submitted",
		"Approved",
		"Rejected",
		"Executed"
	],
	"fields": [
		{
			"name": "co_no",
			"label": "CO number",
			"type": "text",
			"list": true,
			"auto": "CO-",
			"help": "Leave blank to auto-number."
		},
		{
			"name": "title",
			"label": "Title",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "co_type",
			"label": "Type",
			"type": "select",
			"options": [
				"Owner CO",
				"Subcontract CO"
			],
			"list": true
		},
		{
			"name": "cost_code",
			"label": "Cost code (budget line)",
			"type": "select",
			"lookup": {
				"module": "cost-codes",
				"value": "code",
				"label": "title"
			},
			"list": true
		},
		{
			"name": "amount",
			"label": "Amount",
			"type": "currency",
			"required": true,
			"list": true
		},
		{
			"name": "time_extension_days",
			"label": "Time extension (days)",
			"type": "number"
		},
		{
			"name": "executed_date",
			"label": "Executed",
			"type": "date",
			"list": true
		},
		{
			"name": "description",
			"label": "Description",
			"type": "textarea"
		}
	],
	"workflow": {
		"initial": "Draft",
		"states": {
			"Draft": {
				"transitions": [
					{
						"to": "Submitted",
						"label": "Submit",
						"party": [
							"gc"
						],
						"requires": [
							"amount"
						]
					}
				]
			},
			"Submitted": {
				"transitions": [
					{
						"to": "Approved",
						"label": "Approve",
						"party": [
							"owner",
							"rep"
						]
					},
					{
						"to": "Rejected",
						"label": "Reject",
						"party": [
							"owner",
							"rep"
						]
					}
				]
			},
			"Approved": {
				"transitions": [
					{
						"to": "Executed",
						"label": "Execute",
						"party": [
							"gc"
						]
					}
				]
			},
			"Rejected": {
				"transitions": []
			},
			"Executed": {
				"transitions": []
			}
		}
	}
}
