{
	"id": "direct-costs",
	"name": "Direct Costs",
	"section": "cost",
	"icon": "bi-cash-stack",
	"table": "em_direct_costs",
	"version": "1.0.0",
	"statuses": [
		"Pending",
		"Approved",
		"Disputed",
		"Paid"
	],
	"fields": [
		{
			"name": "cost_type",
			"label": "Type",
			"type": "select",
			"options": [
				"Invoice",
				"Certified Payroll",
				"Expense"
			],
			"required": true,
			"list": true
		},
		{
			"name": "vendor",
			"label": "Vendor / employee",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "reference_no",
			"label": "Invoice / reference number",
			"type": "text",
			"list": true
		},
		{
			"name": "cost_code",
			"label": "Cost code (budget line)",
			"type": "select",
			"lookup": {
				"module": "cost-codes",
				"value": "code",
				"label": "title"
			},
			"list": true
		},
		{
			"name": "cost_date",
			"label": "Date",
			"type": "date",
			"list": true
		},
		{
			"name": "amount",
			"label": "Amount",
			"type": "currency",
			"required": true,
			"list": true
		},
		{
			"name": "description",
			"label": "Description",
			"type": "textarea"
		}
	],
	"workflow": {
		"initial": "Pending",
		"states": {
			"Pending": {
				"transitions": [
					{
						"to": "Approved",
						"label": "Approve",
						"party": [
							"gc"
						]
					},
					{
						"to": "Disputed",
						"label": "Dispute",
						"party": [
							"gc"
						]
					}
				]
			},
			"Approved": {
				"transitions": [
					{
						"to": "Paid",
						"label": "Mark paid",
						"party": [
							"gc"
						]
					}
				]
			},
			"Disputed": {
				"transitions": [
					{
						"to": "Pending",
						"label": "Re-submit",
						"party": [
							"gc",
							"subcontractor"
						]
					}
				]
			},
			"Paid": {
				"transitions": []
			}
		}
	}
}
