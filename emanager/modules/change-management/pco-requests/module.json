		{
			"name": "photo_url",
			"label": "Photo link",
			"type": "url"
		},
		{
			"name": "rom_estimate",
			"label": "ROM estimate",
			"type": "currency",
			"list": true
		},
		{
			"name": "cost_impact",
			"label": "Cost impact",
			"type": "checkbox"
		},
		{
			"name": "schedule_impact",
			"label": "Schedule impact",
			"type": "checkbox"
