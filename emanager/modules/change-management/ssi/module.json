						"directions": [
							"P&P",
							"PO",
							"DNP"
						]
					}
				]
			},
			"Assign Contracts": {
				"transitions": [
					{
						"to": "Assign PCO & Funding",
						"label": "Assign contracts",
						"party": [
							"gc"
						]
					}
				]
			},
			"Assign PCO & Funding": {
				"transitions": [
					{
						"to": "Manager Review",
						"label": "Assign PCO# & funding",
						"party": [
							"gc"
						]
					}
				]
			},
			"Manager Review": {
				"transitions": [
					{
						"to": "SSI Approved",
						"label": "Approve",
						"party": [
							"gc"
						]
					}
				]
			},
			"SSI Approved": {
				"transitions": [
					{
						"to": "Issued as SSID",
						"label": "Issue SSID",
						"party": [
							"gc"
						]
					}
				]
			},
			"Issued as SSID": {
				"transitions": []
			}
		}
