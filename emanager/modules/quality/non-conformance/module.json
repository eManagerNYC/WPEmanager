{
	"id": "non-conformance",
	"name": "Non-Conformance Reports",
	"section": "quality",
	"icon": "bi-x-octagon",
	"table": "em_non_conformance",
	"version": "1.0.0",
	"statuses": [
		"Open",
		"Dispositioned",
		"Corrective Action",
		"Verification",
		"Closed"
	],
	"fields": [
		{
			"name": "ncr_no",
			"label": "NCR #",
			"type": "text",
			"list": true,
			"auto": "NCR-",
			"help": "Leave blank to auto-number."
		},
		{
			"name": "title",
			"label": "Title",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "spec_section",
			"label": "Spec section",
			"type": "text",
			"list": true
		},
		{
			"name": "location",
			"label": "Location",
			"type": "select",
			"lookup": {
				"module": "locations",
				"value": "name",
				"label": "name"
			},
			"list": true
		},
		{
			"name": "responsible",
			"label": "Responsible party",
			"type": "text",
			"list": true
		},
		{
			"name": "severity",
			"label": "Severity",
			"type": "select",
			"options": [
				"Minor",
				"Major",
				"Critical"
			],
			"list": true
		},
		{
			"name": "description",
			"label": "Description of non-conformance",
			"type": "textarea",
			"required": true
		},
		{
			"name": "root_cause",
			"label": "Root cause analysis",
			"type": "textarea"
		},
		{
			"name": "corrective_action",
			"label": "Corrective action",
			"type": "textarea"
		},
		{
			"name": "preventive_action",
			"label": "Preventive action",
			"type": "textarea"
		},
		{
			"name": "due_date",
			"label": "Due",
			"type": "date",
			"list": true
		}
	],
	"workflow": {
		"initial": "Open",
		"states": {
			"Open": {
				"transitions": [
					{
						"to": "Dispositioned",
						"label": "Disposition",
						"party": [
							"gc",
							"consultant"
						],
						"directions": [
							"Rework",
							"Repair",
							"Use-as-is",
							"Scrap"
						]
					}
				]
			},
			"Dispositioned": {
				"transitions": [
					{
						"to": "Corrective Action",
						"label": "Assign corrective action",
						"party": [
							"gc"
						]
					}
				]
			},
			"Corrective Action": {
				"transitions": [
					{
						"to": "Verification",
						"label": "Submit for verification",
						"party": [
							"gc",
							"subcontractor"
						],
						"requires": [
							"corrective_action"
						]
					}
				]
			},
			"Verification": {
				"transitions": [
					{
						"to": "Closed",
						"label": "Verify & close",
						"party": [
							"gc",
							"consultant"
						]
					},
					{
						"to": "Corrective Action",
						"label": "Reject — redo",
						"party": [
							"gc",
							"consultant"
						]
					}
				]
			},
			"Closed": {
				"transitions": []
			}
		}
	},
	"relations": [
		{
			"spawn": "action-items",
			"label": "Assign corrective action",
			"map": {
				"title": "title",
				"description": "corrective_action"
			}
		}
	]
}
