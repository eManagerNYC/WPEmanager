{
	"id": "checklists",
	"name": "Checklists",
	"section": "field",
	"icon": "bi-check2-square",
	"table": "em_checklists",
	"version": "1.0.0",
	"statuses": [
		"Open",
		"In Progress",
		"Ready for Review",
		"Failed",
		"Complete"
	],
	"fields": [
		{
			"name": "title",
			"label": "Checklist title",
			"type": "text",
			"required": true,
			"list": true
		},
		{
			"name": "checklist_type",
			"label": "Type",
			"type": "select",
			"options": [
				"Quality",
				"Safety",
				"Pre-pour",
				"MEP Rough-in",
				"Inspection",
				"Commissioning",
				"Other"
			],
			"list": true
		},
		{
			"name": "location",
			"label": "Location",
			"type": "select",
			"lookup": {
				"module": "locations",
				"value": "name",
				"label": "name"
			},
			"list": true
		},
		{
			"name": "responsible",
			"label": "Responsible",
			"type": "text",
			"list": true
		},
		{
			"name": "due_date",
			"label": "Due",
			"type": "date",
			"list": true
		},
		{
			"name": "items",
			"label": "Checklist items",
			"type": "textarea",
			"help": "One item per line"
		},
		{
			"name": "results",
			"label": "Results / notes",
			"type": "textarea"
		}
	],
	"workflow": {
		"initial": "Open",
		"states": {
			"Open": {
				"transitions": [
					{
						"to": "In Progress",
						"label": "Start",
						"party": [
							"gc",
							"subcontractor"
						]
					}
				]
			},
			"In Progress": {
				"transitions": [
					{
						"to": "Ready for Review",
						"label": "Submit for review",
						"party": [
							"gc",
							"subcontractor"
						]
					}
				]
			},
			"Ready for Review": {
				"transitions": [
					{
						"to": "Complete",
						"label": "Pass / complete",
						"party": [
							"gc",
							"consultant"
						]
					},
					{
						"to": "Failed",
						"label": "Fail",
						"party": [
							"gc",
							"consultant"
						]
					}
				]
			},
			"Failed": {
				"transitions": [
					{
						"to": "In Progress",
						"label": "Rework",
						"party": [
							"gc",
							"subcontractor"
						]
					}
				]
			},
			"Complete": {
				"transitions": []
			}
		}
	}
}
